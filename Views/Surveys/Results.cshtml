@model AplikacjaWebowa.ViewModels.SurveyResultsViewModel

@using System.Text.Json

@{
    ViewData["Title"] = "Wyniki ankiety";

    var labels = JsonSerializer.Serialize(
        Model.Options.Select(o => o.Text));

    var values = JsonSerializer.Serialize(
        Model.Options.Select(o => o.VoteCount));
}

<div class="page-header">
    <div>
        <span class="section-label">Statystyki</span>
        <h1 class="page-title">Wyniki ankiety</h1>
        <p class="page-description">
            @Model.Question
        </p>
    </div>

    <div class="results-counter">
        <span>Oddane głosy</span>
        <strong>@Model.TotalVotes</strong>
    </div>
</div>

@if (Model.TotalVotes == 0)
{
    <div class="alert alert-warning">
        W tej ankiecie nie oddano jeszcze żadnego głosu.
    </div>
}
else
{
    <div class="results-layout">
        <div class="content-card chart-card">
            <h3>Wykres wyników</h3>
            <canvas id="resultsChart"></canvas>
        </div>

        <div class="content-card">
            <h3>Szczegółowe wyniki</h3>

            <div class="results-list">
                @foreach (var option in Model.Options)
                {
                    <div class="result-item">
                        <div class="result-item-heading">
                            <strong>@option.Text</strong>
                            <span>
                                @option.VoteCount głosów
                            </span>
                        </div>

                        <div class="result-progress">
                            <div class="result-progress-bar"
                                 style="width: @option.Percentage%">
                            </div>
                        </div>

                        <small>@option.Percentage%</small>
                    </div>
                }
            </div>
        </div>
    </div>
}

<div class="form-actions">
    <a asp-action="Details"
       asp-route-id="@Model.SurveyId"
       class="btn btn-primary">
        Przejdź do ankiety
    </a>

    <a asp-action="Index"
       class="btn btn-secondary">
        Powrót do listy
    </a>
</div>

@section Scripts {
    @if (Model.TotalVotes > 0)
    {
        <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

        <script>
            const chartLabels = @Html.Raw(labels);
            const chartValues = @Html.Raw(values);

            const chartContext =
            document.getElementById('resultsChart');

            new Chart(chartContext, {
            type: 'bar',
            data: {
            labels: chartLabels,
            datasets: [{
            label: 'Liczba głosów',
            data: chartValues,
            borderWidth: 1
            }]
            },
            options: {
            responsive: true,
            scales: {
            y: {
            beginAtZero: true,
            ticks: {
            precision: 0
            }
            }
            }
            }
            });
        </script>
    }
}
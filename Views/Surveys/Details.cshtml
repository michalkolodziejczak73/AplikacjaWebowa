@model AplikacjaWebowa.ViewModels.VoteViewModel

@{
    ViewData["Title"] = "Głosowanie";
}

<div class="page-header">
    <div>
        <span class="section-label">Głosowanie</span>
        <h1 class="page-title">@Model.Question</h1>
        <p class="page-description">
            Wybierz jedną odpowiedź i zatwierdź swój głos.
        </p>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">
        @TempData["SuccessMessage"]
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">
        @TempData["ErrorMessage"]
    </div>
}

<div class="content-card vote-card">
    @if (!Model.IsActive)
    {
        <div class="alert alert-warning mb-0">
            Ta ankieta jest obecnie nieaktywna.
            Nie można oddawać w niej głosów.
        </div>
    }
    else if (Model.AlreadyVoted)
    {
        <div class="alert alert-info mb-0">
            Oddałeś już głos w tej ankiecie.
        </div>
    }
    else
    {
        <form asp-action="Vote" method="post">
            <input asp-for="SurveyId" type="hidden" />

            <div asp-validation-summary="ModelOnly"
                 class="text-danger mb-3"></div>

            <div class="vote-options">
                @foreach (var option in Model.Options)
                {
                    <label class="vote-option"
                           for="option-@option.Id">

                        <input class="form-check-input"
                               type="radio"
                               asp-for="SelectedOptionId"
                               value="@option.Id"
                               id="option-@option.Id" />

                        <span>@option.Text</span>
                    </label>
                }
            </div>

            <span asp-validation-for="SelectedOptionId"
                  class="text-danger d-block mt-2"></span>

            <div class="form-actions">
                <button type="submit"
                        class="btn btn-primary">
                    Oddaj głos
                </button>

                <a asp-action="Results"
                   asp-route-id="@Model.SurveyId"
                   class="btn btn-outline-success">
                    Zobacz wyniki
                </a>

                <a asp-action="Index"
                   class="btn btn-secondary">
                    Powrót
                </a>
            </div>
        </form>
    }

    @if (!Model.IsActive || Model.AlreadyVoted)
    {
        <div class="form-actions">
            <a asp-action="Results"
               asp-route-id="@Model.SurveyId"
               class="btn btn-outline-success">
                Zobacz wyniki
            </a>

            <a asp-action="Index"
               class="btn btn-secondary">
                Powrót
            </a>
        </div>
    }
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
@model AplikacjaWebowa.ViewModels.VoteViewModel

@{
    ViewData["Title"] = "Głosowanie";
}

<h1 class="mb-4">@Model.Question</h1>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">
        @TempData["SuccessMessage"]
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">
        @TempData["ErrorMessage"]
    </div>
}

@if (Model.AlreadyVoted)
{
    <div class="alert alert-info">
        Oddałeś już głos w tej ankiecie.
    </div>
}
else
{
    <form asp-action="Vote" method="post">
        <input asp-for="SurveyId" type="hidden" />

        <div asp-validation-summary="ModelOnly"
             class="text-danger mb-3"></div>

        @foreach (var option in Model.Options)
        {
            <div class="form-check mb-3">
                <input class="form-check-input"
                       type="radio"
                       asp-for="SelectedOptionId"
                       value="@option.Id"
                       id="option-@option.Id" />

                <label class="form-check-label"
                       for="option-@option.Id">
                    @option.Text
                </label>
            </div>
        }

        <span asp-validation-for="SelectedOptionId"
              class="text-danger d-block mb-3"></span>

        <button type="submit" class="btn btn-primary">
            Oddaj głos
        </button>
    </form>
}

<a asp-action="Index"
   class="btn btn-secondary mt-3">
    Powrót do listy
</a>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
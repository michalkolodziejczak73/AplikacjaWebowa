@model AplikacjaWebowa.ViewModels.EditSurveyViewModel

@{
    ViewData["Title"] = "Edytuj ankietę";
}

<div class="page-header">
    <div>
        <span class="section-label">Edycja</span>
        <h1 class="page-title">Edytuj ankietę</h1>
        <p class="page-description">
            Zmień pytanie lub ustaw dostępność głosowania.
        </p>
    </div>
</div>

<div class="content-card form-card">
    <form asp-action="Edit" method="post">
        <input asp-for="Id" type="hidden" />

        <div asp-validation-summary="ModelOnly"
             class="text-danger mb-3"></div>

        <div class="mb-4">
            <label asp-for="Question"
                   class="form-label"></label>

            <input asp-for="Question"
                   class="form-control form-control-lg" />

            <span asp-validation-for="Question"
                  class="text-danger"></span>
        </div>

        <div class="status-switch">
            <div>
                <strong>Dostępność ankiety</strong>
                <p>
                    Po wyłączeniu respondenci nadal zobaczą wyniki,
                    ale nie będą mogli oddać głosu.
                </p>
            </div>

            <div class="form-check form-switch">
                <input asp-for="IsActive"
                       class="form-check-input" />

                <label asp-for="IsActive"
                       class="form-check-label"></label>
            </div>
        </div>

        <div class="form-actions">
            <button type="submit"
                    class="btn btn-warning">
                Zapisz zmiany
            </button>

            <a asp-action="Index"
               class="btn btn-secondary">
                Anuluj
            </a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
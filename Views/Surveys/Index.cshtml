@model IEnumerable<AplikacjaWebowa.Models.Survey>

@{
    ViewData["Title"] = "Ankiety";
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">
        @TempData["SuccessMessage"]
    </div>
}

<div class="page-header">
    <div>
        <span class="section-label">Panel ankiet</span>
        <h1 class="page-title">Dostępne ankiety</h1>
        <p class="page-description">
            Otwórz ankietę, oddaj głos lub sprawdź aktualne wyniki.
        </p>
    </div>

    @if (User.IsInRole("Ankieter"))
    {
        <a asp-action="Create"
           class="btn btn-primary">
            Utwórz ankietę
        </a>
    }
</div>

@if (!Model.Any())
{
    <div class="empty-state">
        <h3>Brak ankiet</h3>
        <p>
            Nie utworzono jeszcze żadnej ankiety.
        </p>

        @if (User.IsInRole("Ankieter"))
        {
            <a asp-action="Create"
               class="btn btn-primary">
                Utwórz pierwszą ankietę
            </a>
        }
    </div>
}
else
{
    <div class="survey-list">
        @foreach (var survey in Model)
        {
            <article class="survey-card">
                <div class="survey-card-main">
                    <div class="survey-card-heading">
                        <div>
                            <h2>@survey.Question</h2>

                            <div class="survey-meta">
                                <span>
                                    Utworzono:
                                    @survey.CreatedAt.ToString("dd.MM.yyyy HH:mm")
                                </span>

                                <span>
                                    Opcje: @survey.Options.Count
                                </span>
                            </div>
                        </div>

                        @if (survey.IsActive)
                        {
                            <span class="status-badge status-active">
                                Aktywna
                            </span>
                        }
                        else
                        {
                            <span class="status-badge status-inactive">
                                Nieaktywna
                            </span>
                        }
                    </div>

                    <div class="survey-actions">
                        <a asp-action="Details"
                           asp-route-id="@survey.Id"
                           class="btn btn-outline-primary">
                            Otwórz ankietę
                        </a>

                        <a asp-action="Results"
                           asp-route-id="@survey.Id"
                           class="btn btn-outline-success">
                            Wyniki
                        </a>

                        @if (User.IsInRole("Ankieter"))
                        {
                            <a asp-action="Votes"
                               asp-route-id="@survey.Id"
                               class="btn btn-outline-dark">
                                Lista głosów
                            </a>

                            <a asp-action="Edit"
                               asp-route-id="@survey.Id"
                               class="btn btn-outline-warning">
                                Edytuj
                            </a>

                            <a asp-action="Delete"
                               asp-route-id="@survey.Id"
                               class="btn btn-outline-danger">
                                Usuń
                            </a>
                        }
                    </div>
                </div>
            </article>
        }
    </div>
}